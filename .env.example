#!/usr/bin/env bash
# Hermes Micro Framework — .env 模板
# 复制到 ~/.hermes/.env 后填入真实值

# ── 向量检索（vdb） ────────────────────────────────────────────
# 硅基流动 BGE-M3 云端嵌入，免费 2000 RPM
# 注册：https://siliconflow.cn → API Key
SILICONFLOW_API_KEY=sk-your-key-here

# ── 可选（以下按需配置，不影响框架运行） ──────────────────────
# OPENROUTER_API_KEY=sk-or-xxx
# ANTHROPIC_API_KEY=sk-ant-xxx
