{
  "log": {"loglevel": "warning"},
  "inbounds": [{
    "listen": "0.0.0.0",
    "port": 8443,
    "protocol": "vless",
    "settings": {"clients":[{"id":"<UUID>","flow":"xtls-rprx-vision"}],"decryption":"none"},
    "streamSettings": {
      "network":"tcp",
      "security":"reality",
      "realitySettings":{
        "dest":"microsoft.com:443",
        "serverNames":["microsoft.com","www.microsoft.com","outlook.com","office.com"],
        "privateKey":"<FROM-xray-x25519-PrivateKey>",
        "shortIds":["","abcd1234"]
      }
    }
  }],
  "outbounds":[{"protocol":"freedom"}]
}
